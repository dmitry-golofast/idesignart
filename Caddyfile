# ===== Caddy — Reverse Proxy + Auto SSL =====
#
# Caddy автоматически получает SSL-сертификаты от Let's Encrypt
# и продлевает их без настройки.
#
# Домены (замените на свои):
#   idesignart.com       → Nuxt (сайт)
#   admin.idesignart.com → Payload (CMS + API)
#   www.idesignart.com   → редирект на idesignart.com

# ===== Публичный сайт (Nuxt) =====
# Переменные из docker-compose: {$SITE_DOMAIN}
{$SITE_DOMAIN} {
	encode zstd gzip

	# Все запросы → Nuxt
	reverse_proxy web:3000

	# Кэшируем статику
	@static {
		path /_nuxt/* /_ipx/* /favicon.ico /robots.txt /sitemap.xml
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	log {
		output stdout
		format console
	}
}

# ===== www → редирект на основной домен =====
www.{$SITE_DOMAIN} {
	redir https://{$SITE_DOMAIN}{uri} permanent
}

# ===== Admin (Payload CMS + API) =====
{$ADMIN_DOMAIN} {
	encode zstd gzip

	# Все запросы → Next.js/Payload
	reverse_proxy admin:3001

	# Media-файлы (загруженные через Payload)
	@api_media {
		path /api/media/* /media/*
	}
	header @api_media Cache-Control "public, max-age=86400"

	# Security headers (мягче для admin — нужен доступ к iframe для previews)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	log {
		output stdout
		format console
	}
}
