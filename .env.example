# ===== Payload =====
# Сгенерируйте свой: openssl rand -hex 32 (или node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYLOAD_SECRET=idesignart-dev-secret-key-2026-change-in-production

# Database
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/idesignart

# Payload server
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ===== Nuxt =====
# URL Payload API (используется в usePayload)
PAYLOAD_API_URL=http://localhost:3001
NUXT_PUBLIC_PAYLOAD_API_URL=http://localhost:3001

# Nuxt server
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== Аналитика (заполняется при запуске) =====
NUXT_PUBLIC_GA_ID=
NUXT_PUBLIC_YANDEX_METRIKA_ID=
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ===== Контакты (отображаются на сайте) =====
NUXT_PUBLIC_WHATSAPP=
NUXT_PUBLIC_TELEGRAM=
NUXT_PUBLIC_PHONE=
NUXT_PUBLIC_EMAIL=hello@idesignart.com
