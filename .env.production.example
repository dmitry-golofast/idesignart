# ========================================
# idesignart — Production Environment
# ========================================
# Скопируйте: cp .env.production.example .env.production
# Заполните все значения и НИКОГДА не коммитьте .env.production

# ===== Домены =====
SITE_DOMAIN=idesignart.com
ADMIN_DOMAIN=admin.idesignart.com

# ===== Безопасность =====
# Сгенерируйте: openssl rand -hex 32
PAYLOAD_SECRET=REPLACE_WITH_SECURE_RANDOM_64_CHARS

# ===== База данных =====
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=idesignart

# ===== Контакты (публичные, отображаются на сайте) =====
WHATSAPP=79991234567
TELEGRAM=idesignart
PHONE=+74951234567
EMAIL=hello@idesignart.com

# ===== Аналитика (оставьте пустым, если не используете) =====
GA_ID=
YANDEX_METRIKA_ID=
PLAUSIBLE_DOMAIN=
